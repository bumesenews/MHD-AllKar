# --- Runtime ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
TRUST_PROXY=true

# --- API protection (required in production) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=123456
REQUIRE_API_KEY=true

# --- CORS (comma-separated Flutter/web app origins) ---
# Example: https://yourapp.com,capacitor://localhost
CORS_ORIGINS=

# --- Rate limits ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
RATE_LIMIT_WATCH_MAX=25

# --- SSRF: only these hosts may be scraped via /api/watch ---
ALLOWED_SCRAPE_HOSTS=www.tubev.sex,tubev.sex
SCRAPE_BASE_URL=https://www.tubev.sex

# --- Scraper HTTP ---
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# --- Cache / cron ---
CACHE_TTL_SECONDS=28800
CACHE_CRON=0 */8 * * *
